{
  "description": "Personality hooks - TTS, context tracking, HUD notifications via psn CLI",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "psn tts mark-natural-stop",
            "timeout": 1000
          },
          {
            "type": "command",
            "command": "psn hud notify Stop",
            "timeout": 500
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "psn hooks session-start",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "psn hud notify SessionStart",
            "timeout": 500
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "psn hooks session-end",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "psn tts stop",
            "timeout": 1000
          },
          {
            "type": "command",
            "command": "psn hud notify SessionEnd",
            "timeout": 500
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "psn tts interrupt-check",
            "timeout": 1000
          },
          {
            "type": "command",
            "command": "psn hud notify UserPromptSubmit",
            "timeout": 500
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "psn hooks notification",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "psn hud notify Notification",
            "timeout": 500
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chi/Projects/personality-plugin/hooks/hud-tool.sh pre",
            "timeout": 500
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chi/Projects/personality-plugin/hooks/hud-tool.sh post",
            "timeout": 500
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "psn context track-read",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
