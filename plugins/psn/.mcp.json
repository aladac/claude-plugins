{
  "mcpServers": {
    "core": {
      "command": "marauder",
      "args": ["mcp", "--mode", "core"]
    },
    "indexer": {
      "command": "marauder",
      "args": ["mcp", "--mode", "indexer"],
      "env": {
        "OLLAMA_URL": "${OLLAMA_URL:-http://localhost:11434}"
      }
    },
    "local": {
      "command": "marauder",
      "args": ["mcp", "--mode", "local"],
      "env": {
        "PERSONALITY_VOICE": "bt7274"
      }
    }
  }
}
