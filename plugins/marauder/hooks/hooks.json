{
  "description": "MARAUDER hooks — TTS, context tracking, permissions, indexing",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chi/.cargo/bin/marauder hooks permission-request",
            "timeout": 2000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chi/.cargo/bin/marauder hooks pre-compact",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chi/.cargo/bin/marauder hooks post-compact",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chi/.cargo/bin/marauder tts mark-natural-stop",
            "timeout": 1000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chi/.cargo/bin/marauder hooks session-start",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chi/.cargo/bin/marauder hooks session-end",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "/Users/chi/.cargo/bin/marauder tts stop",
            "timeout": 1000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chi/.cargo/bin/marauder tts interrupt-check",
            "timeout": 1000
          },
          {
            "type": "command",
            "command": "date '+CLOCK: %A %Y-%m-%d %H:%M %Z'",
            "timeout": 500
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chi/.cargo/bin/marauder hooks notification",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chi/.cargo/bin/marauder index hook",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
