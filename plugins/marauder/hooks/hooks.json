{
  "description": "MARAUDER hooks — TTS, HUD notifications, context tracking, permissions",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "marauder hooks permission-request",
            "timeout": 2000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "marauder hooks pre-compact",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "marauder hooks post-compact",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "marauder tts mark-natural-stop",
            "timeout": 1000
          },
          {
            "type": "command",
            "command": "marauder hud notify Stop",
            "timeout": 500
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "marauder hooks session-start",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "marauder hud notify SessionStart",
            "timeout": 500
          },
          {
            "type": "command",
            "command": "marauder hud update-status",
            "timeout": 1000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "marauder hooks session-end",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "marauder tts stop",
            "timeout": 1000
          },
          {
            "type": "command",
            "command": "marauder hud notify SessionEnd",
            "timeout": 500
          },
          {
            "type": "command",
            "command": "marauder hud session-end",
            "timeout": 500
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "marauder tts interrupt-check",
            "timeout": 1000
          },
          {
            "type": "command",
            "command": "marauder hud notify UserPromptSubmit",
            "timeout": 500
          },
          {
            "type": "command",
            "command": "marauder hud update-status",
            "timeout": 1000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "marauder hooks notification",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "marauder hud notify Notification",
            "timeout": 500
          },
          {
            "type": "command",
            "command": "marauder hud update-status",
            "timeout": 1000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "marauder hud notify-tool pre",
            "timeout": 500
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "marauder hud notify-tool post",
            "timeout": 500
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "marauder hud code-display",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": "marauder index hook",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
